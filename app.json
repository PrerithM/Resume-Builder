{
  "expo": {
    "name": "Profile Builder",
    "slug": "profile-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/Icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.profilebuilder.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app uses your photo library to let you select a profile picture for your resume."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.profilebuilder.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/Icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "This app uses your photo library to let you select a profile picture."
        }
      ]
    ]
  }
}
